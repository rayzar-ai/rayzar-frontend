# .env.example — RayZar Frontend
# Copy to .env.local for local development. NEVER commit .env.local.

# Backend API URL — local dev points to localhost, Vercel points to EC2
NEXT_PUBLIC_API_URL=http://localhost:8000

# API key for X-API-Key header — leave blank in dev (backend skips check)
# In production set this to the same value as API_KEY in rayzar-backend
NEXT_PUBLIC_API_KEY=
